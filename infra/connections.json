{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "location": { "type": "string" },
    "eventGridConnectionName": { "type": "string" },
    "eventGridDisplayName": { "type": "string" }
  },
  "resources": [
    {
      "type": "Microsoft.Web/connections",
      "apiVersion": "2016-06-01",
      "name": "[parameters('eventGridConnectionName')]",
      "location": "[parameters('location')]",
      "properties": {
        "displayName": "[parameters('eventGridDisplayName')]",
        "api": {
          "id": "[concat(subscription().id, '/providers/Microsoft.Web/locations/', parameters('location'), '/managedApis/azureeventgrid')]"
        }
      }
    }
  ],
  "outputs": {
    "eventGridConnectionId": {
      "type": "string",
      "value": "[resourceId('Microsoft.Web/connections', parameters('eventGridConnectionName'))]"
    }
  }
}
